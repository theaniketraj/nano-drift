{
  "name": "nano-drift",
  "displayName": "Nano Drift",
  "description": "Android development at your own pace — build, deploy, and mirror your device inside VS Code.",
  "version": "0.1.0",
  "publisher": "nano-drift",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.87.0",
    "node": ">=18.0.0"
  },
  "categories": ["Other"],
  "keywords": ["android", "adb", "emulator", "mobile", "drift"],
  "icon": "images/icon.png",
  "galleryBanner": { "color": "#0D0D0D", "theme": "dark" },
  "activationEvents": [
    "*",
    "workspaceContains:**/AndroidManifest.xml",
    "workspaceContains:**/build.gradle",
    "workspaceContains:**/build.gradle.kts"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nano-drift",
          "title": "Nano Drift",
          "icon": "images/nano-drift.svg"
        }
      ]
    },
    "views": {
      "nano-drift": [
        {
          "type": "webview",
          "id": "nanoDrift.deviceScreenView",
          "name": "Device Screen"
        }
      ]
    },
    "commands": [
      {
        "command": "nanoDrift.runOnTheFly",
        "title": "Run on the Fly",
        "category": "Android",
        "icon": "$(run)"
      },
      {
        "command": "nanoDrift.selectDevice",
        "title": "Select Active Device",
        "category": "Android",
        "icon": "$(device-mobile)"
      },
      {
        "command": "nanoDrift.startEmulator",
        "title": "Start Headless Emulator",
        "category": "Android",
        "icon": "$(vm)"
      },
      {
        "command": "nanoDrift.connectWifi",
        "title": "Connect Device over Wi-Fi",
        "category": "Android",
        "icon": "$(wifi)"
      },
      {
        "command": "nanoDrift.showDeviceScreen",
        "title": "Focus Device Screen",
        "category": "Android",
        "icon": "$(screen-normal)"
      },
      {
        "command": "nanoDrift.listDevices",
        "title": "List Connected Devices",
        "category": "Android"
      },
      {
        "command": "nanoDrift.stopDaemon",
        "title": "Stop Daemon",
        "category": "Android"
      }
    ],
    "configuration": {
      "title": "Nano Drift",
      "properties": {
        "nanoDrift.androidHome": {
          "type": "string",
          "default": "",
          "description": "Path to Android SDK root. Leave empty to use the ANDROID_HOME environment variable."
        },
        "nanoDrift.daemonPort": {
          "type": "number",
          "default": 27183,
          "description": "WebSocket port used by the Nano Drift daemon."
        },
        "nanoDrift.autoRunOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically build and deploy when a source file is saved."
        },
        "nanoDrift.gradleArgs": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["--parallel"],
          "description": "Extra Gradle arguments (e.g. ['--no-daemon']). The install task is derived from nanoDrift.buildVariant unless this array contains an explicit task name."
        },
        "nanoDrift.buildVariant": {
          "type": "string",
          "default": "debug",
          "description": "Android build variant to install. Determines the Gradle task — 'debug' \u2192 installDebug, 'release' \u2192 installRelease, 'staging' \u2192 installStaging, etc. Has no effect if nanoDrift.gradleArgs already contains an explicit task name."
        },
        "nanoDrift.packageName": {
          "type": "string",
          "default": "",
          "description": "Android application package name (e.g. com.example.myapp). Leave empty to auto-detect from AndroidManifest.xml."
        },
        "nanoDrift.streamCodec": {
          "type": "string",
          "enum": ["png", "h264"],
          "default": "png",
          "description": "Screen streaming codec for Device Screen view. 'png' is stable and works everywhere. 'h264' is experimental and uses WebCodecs when supported."
        }
      }
    },
    "menus": {
      "editor/title/run": [
        {
          "command": "nanoDrift.runOnTheFly",
          "when": "nanoDrift.active",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./",
    "build": "npm run compile",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.87.0",
    "@types/ws": "^8.5.10"
  }
}
